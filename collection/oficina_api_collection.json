          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status ENTREGUE', () => pm.expect(pm.response.json().status).to.eql('ENTREGUE'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ordens/{{ordemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ordens", "{{ordemId}}"]
            }
          }
        },
        {
          "name": "8. Listar OS (ordenadas por status)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Nenhuma OS FINALIZADA ou ENTREGUE na lista', () => {",
                  "  const lista = pm.response.json();",
                  "  lista.forEach(os => {",
                  "    pm.expect(['FINALIZADA','ENTREGUE']).to.not.include(os.status);",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ordens",
              "host": ["{{baseUrl}}"],
              "path": ["ordens"]
            },
            "description": "Lista OS ordenadas por: EXECUCAO > AGUARDANDO_APROVACAO > DIAGNOSTICO > RECEBIDA. FINALIZADA e ENTREGUE não aparecem."
          }
        },
        {
          "name": "9. Soft delete da OS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ordens/{{ordemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ordens", "{{ordemId}}"]
            },
            "description": "Soft delete — seta deletedAt, não remove do banco."
          }
        },
        {
          "name": "10. Buscar OS deletada (erro esperado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status >= 400', () => pm.expect(pm.response.code).to.be.at.least(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ordens/{{ordemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ordens", "{{ordemId}}"]
            },
            "description": "Após soft delete, a OS não deve ser encontrada."
          }
        },
        {
          "name": "Criar OS com dados inválidos (erro esperado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status >= 400', () => pm.expect(pm.response.code).to.be.at.least(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"id-inexistente\",\n  \"veiculoId\": \"id-inexistente\",\n  \"servicos\": [],\n  \"pecas\": [\n    { \"id\": \"id-inexistente\", \"quantidade\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ordens",
              "host": ["{{baseUrl}}"],
              "path": ["ordens"]
            }
          }
        }
      ]
    }
  ]
