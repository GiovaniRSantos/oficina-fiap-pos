{
  "info": {
    "name": "Oficina API — Tech Challenge Fase 2",
    "_postman_id": "oficina-api-fase2",
    "description": "Collection baseada no fluxo E2E completo da Oficina API.\n\n**Fluxo recomendado:**\n1. Auth → Login\n2. Clientes → Criar\n3. Veículos → Criar\n4. Serviços → Criar\n5. Peças → Criar\n6. Ordens → Criar\n7. Ordens → Avançar status (DIAGNOSTICO → AGUARDANDO_APROVACAO)\n8. Ordens → Aprovar orçamento\n9. Ordens → Finalizar (FINALIZADA → ENTREGUE)\n10. Ordens → Listar\n11. Ordens → Soft Delete",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "clienteId",
      "value": "",
      "type": "string"
    },
    {
      "key": "veiculoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "servicoId",
      "value": "",
      "type": "string"
    },
    {
      "key": "pecaId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ordemId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token salvo:', json.token);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token retornado', () => pm.expect(json.token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica e salva o token automaticamente na variável `token`."
          }
        },
        {
          "name": "Login — credenciais inválidas (erro esperado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"senha_errada\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
